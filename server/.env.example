# ── Threads Batch Tool ──────────────────────────
BUFFER_API_KEY=your-buffer-api-key
BUFFER_THREADS_CHANNEL_ID=your-buffer-threads-channel-id
THREADS_TOOL_PASSWORD=ferixdiai
GEMINI_MODEL=gemini-2.5-flash-preview-05-20
GEMINI_USE_GROUNDING=true
